# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_id_here

# MySQL Database Configuration (optional if using PlatformSync)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=your_database_name

# BattleMetrics API Configuration
BATTLEMETRICS_API_KEY=your_battlemetrics_api_key_here
BATTLEMETRICS_SERVER_ID=your_rust_server_id_here

# PlatformSync API Configuration
# Get your API key from https://www.platformsync.io/
PLATFORMSYNC_API_KEY=your_platformsync_api_key_here

# Environment
NODE_ENV=development
